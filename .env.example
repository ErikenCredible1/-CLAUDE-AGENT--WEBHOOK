# Telegram Bot credentials (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your Telegram user ID (get it from @userinfobot on Telegram)
TELEGRAM_USER_ID=your_user_id_here

# OpenRouter (from openrouter.ai)
OPENROUTER_API_KEY=sk-or-your_key_here

# Model to use (can swap to any OpenRouter model)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Optional: Tavily API for web search (tavily.com - free tier available)
TAVILY_API_KEY=tvly-your_key_here

# Server port
PORT=3000

# Synology MariaDB (via Tailscale)
DB_HOST=100.x.x.x
DB_PORT=3306
DB_USER=lineagent
DB_PASSWORD=yourpassword
DB_NAME=lineagent

# QStash (from upstash.com/qstash)
QSTASH_TOKEN=your_qstash_token_here

# Your Render URL (no trailing slash)
RENDER_URL=https://your-app.onrender.com

# Random secret to secure your /scheduled endpoint (make up any string)
SCHEDULED_SECRET=make_up_a_random_string_here

# Your timezone offset from UTC (e.g. 7 for Bangkok, -5 for EST, 0 for London)
TIMEZONE_OFFSET=7

# Google OAuth2 credentials (see README for setup guide)
# Get these from console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Generate via OAuth Playground: https://developers.google.com/oauthplayground
# Required scopes: Gmail, Drive, Calendar, Sheets (see README)
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
